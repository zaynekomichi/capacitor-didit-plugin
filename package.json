{
  "name": "capacitor-didit-plugin",
  "version": "0.1.2",
  "description": "Capacitor plugin wrapping the native Didit identity verification (KYC) SDKs for iOS and Android",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "android/proguard-rules.pro",
    "dist/",
    "ios/Sources",
    "ios/Tests",
    "Package.swift",
    "CapacitorDiditPlugin.podspec"
  ],
  "author": "Aurora Systems <zkomichi@aurorasystems.co.zw>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zaynekomichi/capacitor-didit-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/zaynekomichi/capacitor-didit-plugin/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "didit",
    "kyc",
    "identity-verification",
    "liveness"
  ],
  "scripts": {
    "verify": "npm run verify:web",
    "verify:web": "npm run build",
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.30.1",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
